{"timestamp":"2026-04-22T06:52:00.807831Z","level":"info","event":"Running command: \n            bash -lc '\n            echo \"==============================\"\n            echo \"TABLE START: auth\"\n            echo \"==============================\"\n\n            # --------------------------------------------------\n            # 1. HDFS partition directory 생성 (-3 ~ +3)\n            # --------------------------------------------------\n            for i in $(seq -3 3);\n            do\n                date=$(date -d \"$i days\" +%Y%m%d)\n                echo \"CREATE HDFS: /hive/auth/dt=$date\"\n\n                hdfs dfs -mkdir -p /hive/auth/dt=$date\n            done\n\n            # --------------------------------------------------\n            # 2. MSCK REPAIR\n            # --------------------------------------------------\n            echo \"MSCK START: auth\"\n\n            beeline -u jdbc:hive2://localhost:10000/default             -e \"MSCK REPAIR TABLE auth\";\n\n            # --------------------------------------------------\n            # 3. VERIFY\n            # --------------------------------------------------\n            echo \"SHOW PARTITIONS: auth\"\n\n            beeline -u jdbc:hive2://localhost:10000/default             -e \"SHOW PARTITIONS auth\";\n\n            echo \"==============================\"\n            echo \"TABLE END: auth\"\n            echo \"==============================\"\n            '\n            ","logger":"airflow.task.hooks.airflow.providers.ssh.hooks.ssh.SSHHook","filename":"ssh.py","lineno":449}
